# Required for the AI use-case audit demo at /api/audit.
# Get a free key from https://aistudio.google.com/apikey
# Free tier: 15 requests/minute, 1,500 requests/day on gemini-2.5-flash.
GOOGLE_API_KEY=

# Optional. Override the default Gemini model used by the audit demo.
# Defaults to "gemini-2.5-flash" if unset.
# GEMINI_AUDIT_MODEL=gemini-2.5-flash

# Optional. Set to "0" in production to hide upstream error details
# from the audit demo's user-facing error toast. Leave unset (or set to
# anything other than "0") to keep the debug-friendly verbose errors.
# GEMINI_AUDIT_DEBUG=0
